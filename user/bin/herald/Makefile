# herald — package manager. Links the in-tree BearSSL (ECDSA P-256 + SHA-256).
# trusted_key.h is generated by tools/herald-keygen.sh into build/herald-keys/
# (top Makefile dep) and found via -I below.

# CC / BEARSSL / MUSL_DIR / HERALD_ARCH are overridable on the command line so
# the same client cross-builds per arch (arm64: pass the aarch64 musl gcc, the
# aarch64 BearSSL, and HERALD_ARCH=arm64).
MUSL_DIR = ../../../build/musl-dynamic
BEARSSL  = ../../../build/bearssl-install
KEYDIR   = ../../../build/herald-keys
CC       = $(MUSL_DIR)/usr/bin/musl-gcc
HERALD_ARCH = x86_64

CFLAGS  = -O2 -s -fno-pie -no-pie -Wall -Wextra -Wl,--build-id=none \
          -DHERALD_ARCH='"$(HERALD_ARCH)"' -I$(BEARSSL)/include -I$(KEYDIR)
LDFLAGS = -static -no-pie -L$(BEARSSL)/lib -L$(BEARSSL)/lib64 -lbearssl

SRCS = main.c tar.c verify.c manifest.c db.c net.c repo.c
HDRS = tar.h verify.h manifest.h db.h net.h repo.h

# OUT is overridable so cross-arch builds write to a distinct path. Sharing one
# herald.elf let the arm64 build clobber the native binary; make then saw it as
# up-to-date and the x86_64 rootfs silently shipped an AArch64 herald the kernel
# rejects at exec ("not an ELF64 executable for this arch").
OUT ?= herald.elf

$(OUT): $(SRCS) $(HDRS)
	$(CC) $(CFLAGS) -o $@ $(SRCS) $(LDFLAGS)

clean:
	rm -f *.elf

.PHONY: clean
