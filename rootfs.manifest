# Aegis rootfs manifest — single source of truth for disk contents
#
# Format: SOURCE DEST
# - Lines starting with # are comments, blank lines ignored
# - Parent directories are created automatically
# - Everything under /bin, /lib and /apps gets mode 0100755
# - Everything else keeps default mode (0644)
#   (app.ini manifests are NOT listed here — they live in the rootfs/
#   skeleton at rootfs/apps/<id>/app.ini and are copied with mode 0644)

# Dynamic linker — single real copy at the PT_INTERP path; build-rootfs.sh
# creates /lib/libc.so as an ext2 symlink to it (debugfs `symlink`).
build/musl-dynamic/usr/lib/libc.so  /lib/ld-musl-x86_64.so.1

# Core system binaries
user/bin/shell/shell.elf        /bin/sh
# C++ runtime smoke test (browser-port P1 gate) — built with the Aegis C++
# cross toolchain (GCC 15.1 musl). Proves exceptions/RTTI/STL/iostream on Aegis.
build/cpptest                   /bin/cpptest
user/bin/login/login.elf        /bin/login
user/bin/vigil/vigil            /bin/vigil
user/bin/vigictl/vigictl        /bin/vigictl
user/bin/stsh/stsh.elf          /bin/stsh
user/bin/installer/installer.elf /bin/installer

# SSH server: tinysshd (daemon) + sshd (TCP superserver front-end) +
# tinysshd-makekey (ed25519 host-key generation at first boot).
user/bin/sshd/sshd.elf          /bin/sshd
build/tinyssh/tinysshd          /bin/tinysshd
build/tinyssh/tinysshd-makekey  /bin/tinysshd-makekey

# herald — package manager (links BearSSL). Signed sample package + its
# detached signature are staged for the demo and tests/tests/herald_test.rs.
user/bin/herald/herald.elf      /bin/herald
build/herald-sample.hpkg        /usr/share/herald/sample.hpkg
build/herald-sample.hpkg.sig    /usr/share/herald/sample.hpkg.sig

